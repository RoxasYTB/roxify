{
  "name": "roxify",
  "version": "1.5.0",
  "description": "Ultra-lightweight PNG steganography with native Rust acceleration. Encode binary data into PNG images with zstd compression.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "rox": "dist/cli.js",
    "roxify": "dist/cli.js"
  },
  "files": [
    "dist",
    "libroxify_native.node",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:native": "cargo build --release --lib && cp target/release/libroxify_native.so libroxify_native.node",
    "build:cli": "cargo build --release --bin roxify_native && cp target/release/roxify_native dist/roxify-cli",
    "build:all": "npm run build:native && npm run build && npm run build:cli",
    "prepublishOnly": "npm run build:all",
    "test": "npm run build && node test/run-all-tests.js",
    "cli": "node dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/roxify.git"
  },
  "keywords": [
    "steganography",
    "png",
    "compression",
    "zstd",
    "rust",
    "native",
    "encode",
    "decode",
    "binary",
    "lightweight"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
