# Configuration optimisée pour Glados-Disc
NODE_ENV=production

# Optimisation mémoire - IMPORTANT !
TOTAL_SHARDS=4
SHARD_MEMORY_LIMIT=256
DISCORD_CACHE_ENABLED=false
GC_AGGRESSIVE=true

# Performance Node.js
UV_THREADPOOL_SIZE=4

# Discord (remplacez par votre token)
# TOKEN=votre_token_ici

# Environnement
ENV=PROD